rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(docData) {
      return request.auth != null && request.auth.uid == docData.uid;
    }

    function isFollower(docData) {
      return request.auth != null && request.auth.uid in docData.followedBy;
    }

    match /Users/{docId} {
      allow read:   if isOwner(resource.data);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update: if isOwner(resource.data);
      allow delete: if false;
    }

    match /Users/{docId}/WatchItems/{itemId} {
      allow read:  if true;  // Public: docId is only known to people the user shared the link with
      allow write: if isOwner(get(/databases/$(database)/documents/Users/$(docId)).data);
    }

    match /WatchItems/{itemId} {
      allow read:  if true;
      allow write: if false;
    }
  }
}